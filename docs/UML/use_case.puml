@startuml UseCase
left to right direction

actor "User" as U
actor "Server" as S

rectangle "Authentication" {
    usecase "Register" as UC1
    usecase "Login" as UC2
    usecase "Logout" as UC3
}

rectangle "Chat Room Management" {
    usecase "Create Chat Room" as UC4
    usecase "Join Chat Room" as UC5
    usecase "Leave Chat Room" as UC6
    usecase "Invite User to Room" as UC7
    usecase "Accept Invitation" as UC8
    usecase "Decline Invitation" as UC9
}

rectangle "Messaging" {
    usecase "Send Message" as UC10
    usecase "Receive Message" as UC11
    usecase "View Message History" as UC12
    usecase "Send Emoji" as UC13
    usecase "Attach Image" as UC14
}

rectangle "Chat History" {
    usecase "Save Chat History" as UC15
}

rectangle "Settings & Appearance" {
    usecase "Toggle Theme" as UC16
}

rectangle "Connection" {
    usecase "Monitor Connection Status" as UC17
}

U --> UC1
U --> UC2
U --> UC3

U --> UC4
U --> UC5
U --> UC6
U --> UC7
U --> UC8
U --> UC9

U --> UC10
U --> UC11
U --> UC12
U --> UC13
UC13 .> UC10 : <<extends>>
U --> UC14
UC14 .> UC10 : <<extends>>

U --> UC15

U --> UC16

U --> UC17

S --> UC11
S --> UC17

UC2 .> UC5 : <<includes>>

@enduml