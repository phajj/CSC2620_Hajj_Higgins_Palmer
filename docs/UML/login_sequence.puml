@startuml LoginSequence

title Login and Registration Sequence

actor User
participant GUI
participant Client
participant LoginHandler
participant CredentialHandler

' LOGIN FLOW
group Login
    User -> GUI : enters username and password, clicks Login
    GUI -> Client : connect(username, password, gui)
    Client -> LoginHandler : getInstance()
    Client -> LoginHandler : login(username, password)

    LoginHandler -> LoginHandler : validateUsernameFormat(username)
    LoginHandler -> LoginHandler : validatePasswordFormat(password)

    alt Invalid format
        LoginHandler --> Client : throws InvalidLoginException
        Client --> GUI : propagates exception
        GUI -> GUI : showLoginError(message)
        GUI -> User : displays format error
    else Valid format
        LoginHandler -> CredentialHandler : getInstance("credentials.txt")
        LoginHandler -> CredentialHandler : lookup(username)
        CredentialHandler --> LoginHandler : storedPassword (or null)

        alt Passwords match
            LoginHandler --> Client : true
            Client -> Client : open socket, start Sender and Receiver
            Client --> GUI : (returns normally)
               Client -> Sender : enter(username)
               Client -> Client : connectionChecker = new ConnectionChecker(sender, gui)
               Client -> Client : connectionChecker.start()
            GUI -> GUI : showChatScreen()
            GUI -> User : chat screen shown
        else No match / user not found
            LoginHandler --> Client : throws InvalidLoginException
            Client --> GUI : propagates exception
            GUI -> GUI : showLoginError(message)
            GUI -> User : displays credentials error
        end
    end
end

' REGISTRATION FLOW
group Registration
    User -> GUI : enters username and password, clicks Register
    GUI -> Client : register(username, password)
    Client -> LoginHandler : getInstance()
    Client -> LoginHandler : register(username, password)

    LoginHandler -> LoginHandler : validateUsernameFormat(username)
    LoginHandler -> LoginHandler : validatePasswordFormat(password)

    alt Invalid format
        LoginHandler --> Client : throws RegistrationException
        Client --> GUI : propagates exception
        GUI -> GUI : showLoginError(message)
        GUI -> User : displays format error
    else Valid format
        LoginHandler -> CredentialHandler : getInstance("credentials.txt")
        LoginHandler -> CredentialHandler : register(username, password)

        alt Username already exists
            CredentialHandler --> LoginHandler : throws RegistrationException
            LoginHandler --> Client : propagates exception
            Client --> GUI : propagates exception
            GUI -> GUI : showLoginError(message)
            GUI -> User : displays duplicate username error
        else Registration successful
            CredentialHandler -> CredentialHandler : write to credentials.txt
            CredentialHandler --> LoginHandler : (returns)
            LoginHandler --> Client : (returns)
            Client --> GUI : (returns)
            GUI -> GUI : showLoginSuccess("Registration successful")
            GUI -> User : success message shown
        end
    end
end

@enduml
