@startuml CredentialHandler_CRC

title CredentialHandler — CRC Diagram


class CredentialHandler {
  == Responsibilities ==
  Enforce Singleton instantiation
  Load credentials from credentials.txt into a HashMap on startup
  Look up a stored password by username
  Persist a new username/password pair to credentials.txt
  Report whether any credentials currently exist
  Throw RegistrationException when username already exists
  --
  == Collaborators ==
  RegistrationException
}

class RegistrationException {
  (collaborator)
}

CredentialHandler ..> RegistrationException : throws >

@enduml
